{
    "name": "@heroesofcrypto/common",
    "version": "0.1.5",
    "description": "Common game logic for Heroes of Crypto. Used on both client and server sides",
    "homepage": "https://heroesofcrypto.io",
    "repository": {
        "type": "git",
        "url": "https://github.com/o1dstaRs/heroes-of-crypto-common.git"
    },
    "type": "module",
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "source": "./src/index.ts",
    "types": "./src/index.ts",
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "prebuild": "rimraf dist && bun run fmt",
        "build": "bun test --timeout 30000 && tsc -p tsconfig.build.json && bun run copy-json && bun run copy-generated",
        "build:proto": "bun add -d protoc-gen-ts; scripts/protoc_generate.sh",
        "copy-generated": "bunx cpy \"src/generated/**/*\" \"dist/generated\"",
        "copy-json": "bunx cpy \"src/**/*.json\" dist --parents",
        "fmt": "bunx prettier \"src/**/*.ts\" --write",
        "lint": "bun run lint:es && bun run lint:package && bun run lint:style",
        "lint:es": "bunx eslint \"src/**/*.{ts,tsx}\" --ignore-pattern .prettierignore",
        "lint:es:fix": "bun run lint:es -- --fix",
        "lint:fix": "bun run lint:es:fix && bun run lint:package:fix && bun run lint:style:fix",
        "lint:package": "bun run lint:package:fix -- --check",
        "lint:package:fix": "bunx sort-package-json package.json",
        "lint:style": "bun run lint:style:base -- --check",
        "lint:style:base": "bunx prettier \"src/**/*.{ts,tsx,js,json}\"",
        "lint:style:fix": "bun run lint:style:base -- --write",
        "prepare": "git config core.hooksPath .githooks || true",
        "test": "bun test --timeout 30000"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "bunx eslint --fix",
            "bunx prettier --write"
        ],
        "*.{js,json}": [
            "bunx prettier --write"
        ]
    },
    "browserslist": [
        "> 5%"
    ],
    "dependencies": {
        "@types/bun": "^1.3.14",
        "@types/google-protobuf": "^3.15.12",
        "@types/uuid": "^11.0.0",
        "denque": "^2.1.0",
        "uuid": "^11.1.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "cpy-cli": "^7.0.0",
        "eslint": "^9.39.4",
        "google-protobuf": "^4.0.2",
        "lint-staged": "^17.0.8",
        "prettier": "3.9.1",
        "protobufjs": "^7.6.4",
        "protoc-gen-js": "^3.21.4-4",
        "protoc-gen-ts": "^0.8.7",
        "rimraf": "^6.1.3",
        "sort-package-json": "^3.7.1",
        "ts-protoc-gen": "^0.15.0",
        "typescript": "^5.9.0"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
