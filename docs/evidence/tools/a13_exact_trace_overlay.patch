+/*
+ * Temporary, external-only instrumentation for the a13 ray-traversal differential.
+ * This file is installed into immutable source archives by the evidence harness;
+ * it is deliberately not part of production source.
+ */
+
+import type { FightProperties } from "../fights/fight_properties";
+import type { Grid } from "../grid/grid";
+import type { IDamageStatistic } from "../scene/scene_stats";
+import type { UnitsHolder } from "../units/units_holder";
+import { snapshotBattle } from "./battle_snapshot";
+import type { SearchDriver } from "./search_driver";
+
+export interface IExactTraceBoundaryInput {
+    kind: string;
+    events?: readonly unknown[];
+    detail?: unknown;
+    unitsHolder: UnitsHolder;
+    grid: Grid;
+    fightProperties: FightProperties;
+    damageStatistics: readonly IDamageStatistic[];
+    currentActiveUnitId: string;
+    search: SearchDriver;
+    outerState: unknown;
+}
+
+export interface IExactTraceBoundary {
+    kind: string;
+    events: unknown;
+    detail: unknown;
+    state: unknown;
+}
+
+type ExactTraceObserver = (boundary: IExactTraceBoundary) => void;
+
+let observer: ExactTraceObserver | undefined;
+let combatRandomDraws = 0;
+
+export function installExactTraceObserver(next: ExactTraceObserver): void {
+    observer = next;
+    combatRandomDraws = 0;
+}
+
+export function clearExactTraceObserver(): void {
+    observer = undefined;
+    combatRandomDraws = 0;
+}
+
+export function exactTraceEnabled(): boolean {
+    return observer !== undefined;
+}
+
+export function exactTraceRandomSource(source: () => number): () => number {
+    if (!observer) {
+        return source;
+    }
+    combatRandomDraws = 0;
+    return () => {
+        combatRandomDraws += 1;
+        return source();
+    };
+}
+
+function normalize(value: unknown, ancestors: Set<object> = new Set()): unknown {
+    if (typeof value === "function" || typeof value === "symbol") {
+        throw new Error(`exact trace encountered unsupported ${typeof value}`);
+    }
+    if (value === undefined) {
+        return { $undefined: true };
+    }
+    if (typeof value === "number") {
+        if (Number.isNaN(value)) return { $number: "NaN" };
+        if (value === Number.POSITIVE_INFINITY) return { $number: "+Infinity" };
+        if (value === Number.NEGATIVE_INFINITY) return { $number: "-Infinity" };
+        if (Object.is(value, -0)) return { $number: "-0" };
+        return value;
+    }
+    if (typeof value === "bigint") {
+        return { $bigint: value.toString() };
+    }
+    if (value === null || typeof value !== "object") {
+        return value;
+    }
+    if (ancestors.has(value)) {
+        throw new Error("exact trace encountered an unexpected cycle");
+    }
+    if (value instanceof WeakMap || value instanceof WeakSet || value instanceof WeakRef) {
+        throw new Error(`exact trace encountered unsupported ${value.constructor.name}`);
+    }
+    const nextAncestors = new Set(ancestors);
+    nextAncestors.add(value);
+    if (value instanceof Map) {
+        return {
+            $map: [...value.entries()].map(([key, item]) => [
+                normalize(key, nextAncestors),
+                normalize(item, nextAncestors),
+            ]),
+        };
+    }
+    if (value instanceof Set) {
+        return { $set: [...value.values()].map((item) => normalize(item, nextAncestors)) };
+    }
+    if (ArrayBuffer.isView(value)) {
+        const view = value as unknown as { readonly length: number; readonly [index: number]: number };
+        return {
+            $typedArray: value.constructor.name,
+            values: Array.from({ length: view.length }, (_, index) => normalize(view[index], nextAncestors)),
+        };
+    }
+    if (Array.isArray(value)) {
+        return value.map((item) => normalize(item, nextAncestors));
+    }
+    const maybeQueue = value as { toArray?: () => unknown[] };
+    if (value.constructor?.name === "Denque" && typeof maybeQueue.toArray === "function") {
+        return { $denque: maybeQueue.toArray().map((item) => normalize(item, nextAncestors)) };
+    }
+    const record = value as Record<string, unknown>;
+    const out: Record<string, unknown> = {};
+    const constructorName = value.constructor?.name;
+    if (constructorName && constructorName !== "Object") {
+        out.$type = constructorName;
+    }
+    for (const key of Object.keys(record).sort()) {
+        out[key] = normalize(record[key], nextAncestors);
+    }
+    return out;
+}
+
+function stableSearchState(search: SearchDriver): unknown {
+    const raw = search as unknown as Record<string, unknown>;
+    const counters = { ...(raw.counters as Record<string, unknown>) };
+    delete counters.msTotal;
+    return normalize({
+        circuitOpen: raw.circuitOpen,
+        counters,
+        datasetRows: raw.datasetRows,
+        finishPressureState: raw.finishPressureState,
+        finishedSim: raw.finishedSim,
+        ilRows: raw.ilRows,
+        pureRangedTerminalState: raw.pureRangedTerminalState,
+        rolloutEnemyTeam: raw.rolloutEnemyTeam,
+        turnRows: raw.turnRows,
+    });
+}
+
+export function emitExactTraceBoundary(input: IExactTraceBoundaryInput): void {
+    if (!observer) {
+        return;
+    }
+    const snapshot = snapshotBattle(input.unitsHolder, input.grid, input.fightProperties);
+    const fight = { ...snapshot.fight };
+    // UUID construction and timing bookkeeping do not affect combat semantics and are not repeat-stable.
+    delete fight.id;
+    delete fight.currentTurnStart;
+    delete fight.currentTurnEnd;
+    delete fight.currentLapTotalTimePerTeam;
+    observer({
+        kind: input.kind,
+        events: normalize(input.events ?? []),
+        detail: normalize(input.detail),
+        state: normalize({
+            activeUnitId: input.currentActiveUnitId,
+            aiTargetMemory: snapshot.aiTargetMemory,
+            combatRandomDraws,
+            damageStatistics: input.damageStatistics,
+            fight,
+            grid: snapshot.grid,
+            holder: snapshot.holder,
+            outer: input.outerState,
+            search: stableSearchState(input.search),
+            unitOrder: snapshot.unitOrder,
+            units: snapshot.units,
+        }),
+    });
+}
